meta {
  name: send-notification
  type: http
  seq: 9
}

put {
  url: {{io-func-sign-issuer-base-url}}/sign/signature-requests/:signature_request_id/notification
  body: none
  auth: inherit
}

params:path {
  signature_request_id: {{signature_request_id}}
}

settings {
  encodeUrl: false
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
