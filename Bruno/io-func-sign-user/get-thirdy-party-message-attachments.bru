meta {
  name: get-thirdy-party-message-attachments
  type: http
  seq: 7
}

get {
  url: {{io-func-sign-user-base-url}}/sign/messages/:signatureRequestId/:documentId
  body: none
  auth: inherit
}

params:path {
  documentId: {{signature_request_document_id}}
  signatureRequestId: {{signature_request_id}}
}

headers {
  fiscal_code: {{fiscal_code}}
}

settings {
  encodeUrl: true
  timeout: 0
}
